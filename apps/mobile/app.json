{
  "expo": {
    "name": "MediaOS",
    "slug": "mediaos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "mediaos",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#191c1f"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mediaos.app",
      "infoPlist": {
        "NSCameraUsageDescription": "لالتقاط صور وفيديو للإنتاج",
        "NSPhotoLibraryUsageDescription": "لرفع صور وفيديو للمكتبة الرقمية",
        "NSFaceIDUsageDescription": "للمصادقة السريعة بـ Face ID"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#191c1f"
      },
      "package": "com.mediaos.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE", "USE_BIOMETRIC", "USE_FINGERPRINT"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      ["expo-camera", { "cameraPermission": "السماح لـ MediaOS بالوصول إلى الكاميرا" }],
      ["expo-local-authentication", { "faceIDPermission": "السماح لـ MediaOS باستخدام Face ID" }]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
