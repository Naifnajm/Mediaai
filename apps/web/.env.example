# ═══════════════════════════════════════════════════════
#  MediaOS Web — Environment Variables
# ═══════════════════════════════════════════════════════

# Odoo Connection (REQUIRED)
NEXT_PUBLIC_ODOO_URL=https://your-odoo-server.com
NEXT_PUBLIC_ODOO_DB=MediaAi
NEXT_PUBLIC_APP_NAME=MediaOS

# Admin (server-side only — never expose to client)
ODOO_ADMIN_PASSWORD=your-admin-password
